# Crystallize tenant + Core API credentials
# Create a token pair at: https://crystallize.com → Settings → Access tokens
CRYSTALLIZE_TENANT_IDENTIFIER=your-tenant-identifier
CRYSTALLIZE_ACCESS_TOKEN_ID=your-token-id
CRYSTALLIZE_ACCESS_TOKEN_SECRET=your-token-secret

# Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Public URL used by the custom view.
# Local dev: http://localhost:4000
# Sharing with others via ngrok: https://your-tunnel.ngrok-free.app
# Production: your deployed origin
NEXT_PUBLIC_APP_URL=http://localhost:4000
